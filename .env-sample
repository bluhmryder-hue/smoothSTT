# SmoothSTT Configuration Template
# Created: $(date -u +"%Y-%m-%dT%H:%M:%SZ")

# --- AI & STT ---
# Absolute path to your Whisper GGML model (.bin)
WHISPER_MODEL_PATH="C:/SmoothSTT/models/ggml-base.en.bin"

# --- AUTOMATION ---
# Trigger Key Code (Windows Virtual Key Code)
# 0x14 = Caps Lock, 0x70 = F1
TRIGGER_KEY_CODE=20

# --- AUDIO ---
# Target mixer index (run test-harness.js --list-devices to find yours)
AUDIO_DEVICE_ID=0

# --- SETTINGS ---
# Enable automatic text injection via ClipPaste.exe
AUTO_PASTE_ENABLED=true

# Logging Level (debug, info, warn, error)
LOG_LEVEL="info"
